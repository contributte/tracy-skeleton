{
  "name": "contributte/tracy-skeleton",
  "description": "Example Nette skeleton focused on secure Tracy BlueScreen sharing for AI workflows.",
  "keywords": [
    "nette",
    "skeleton",
    "project",
    "logging",
    "tracy",
    "security"
  ],
  "license": "MIT",
  "type": "project",
  "require": {
    "php": ">=8.4",
    "contributte/nella": "^0.2",
    "contributte/tracy": "^0.6"
  },
  "require-dev": {
    "contributte/qa": "^0.4",
    "contributte/dev": "^0.6",
    "contributte/phpstan": "^0.1",
    "contributte/tester": "^0.3"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests"
    }
  },
  "prefer-stable": true,
  "minimum-stability": "dev",
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
